{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Postgres Configuration",
  "description": "Configuration for Managed Postgres (Crunchy PGO)",
  "type": "object",
  "required": ["tenant", "name"],
  "properties": {
    "tenant": {
      "type": "string",
      "description": "Owning tenant name",
      "pattern": "^([a-z][a-z0-9-]*)?$",
      "maxLength": 63
    },
    "name": {
      "type": "string",
      "description": "Postgres instance name",
      "pattern": "^[a-z][a-z0-9-]*$",
      "minLength": 1,
      "maxLength": 63
    },
    "version": {
      "type": "integer",
      "description": "PostgreSQL major version",
      "enum": [13, 14, 15, 16],
      "default": 16
    },
    "replicas": {
      "type": "integer",
      "description": "Number of Postgres replicas (1 = single primary)",
      "minimum": 1,
      "maximum": 5,
      "default": 1
    },
    "storageSize": {
      "type": "string",
      "description": "Persistent volume size per replica",
      "pattern": "^[0-9]+(Mi|Gi|Ti)$",
      "default": "10Gi"
    },
    "storageClass": {
      "type": "string",
      "description": "StorageClass for persistent volumes (blank = cluster default)",
      "default": ""
    },
    "resources": {
      "type": "object",
      "description": "Database pod resource requests and limits",
      "default": {},
      "properties": {
        "cpu":          { "type": "string", "default": "250m" },
        "memory":       { "type": "string", "default": "512Mi" },
        "cpuLimit":     { "type": "string", "default": "1" },
        "memoryLimit":  { "type": "string", "default": "2Gi" }
      }
    },
    "backups": {
      "type": "object",
      "description": "Backup configuration (pgBackRest)",
      "default": {},
      "properties": {
        "enabled":  { "type": "boolean", "default": true },
        "schedule": {
          "type": "string",
          "description": "Cron schedule for full backups",
          "default": "0 1 * * 0"
        },
        "retention": {
          "type": "integer",
          "description": "Number of full backups to keep",
          "minimum": 1,
          "maximum": 30,
          "default": 7
        }
      }
    },
    "users": {
      "type": "array",
      "description": "Database users. Each gets a Crunchy-managed Secret and a Vault PushSecret.",
      "minItems": 1,
      "default": [{ "name": "app", "databases": ["app"] }],
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Postgres username",
            "pattern": "^[a-z][a-z0-9_]*$",
            "minLength": 1,
            "maxLength": 63
          },
          "databases": {
            "type": "array",
            "description": "Databases this user owns (first one is the default DB in the connection URI)",
            "default": ["app"],
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$",
              "minLength": 1,
              "maxLength": 63
            }
          }
        }
      }
    }
  }
}
